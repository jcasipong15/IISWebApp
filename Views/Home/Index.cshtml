@model IEnumerable<IISWebApp.Models.SiteViewModel>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2 text-primary me-2"></i>Dashboard</h2>
    <button class="btn btn-outline-primary shadow-sm" onclick="window.location.reload();">
        <i class="bi bi-arrow-clockwise me-1"></i> Refresh
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger shadow-sm">
        <h4 class="alert-heading"><i class="bi bi-x-circle-fill me-2"></i>Connection Error</h4>
        <p>@ViewBag.ErrorMessage</p>
    </div>
}
else if (Model != null && Model.Any())
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var site in Model)
        {
            var isRunning = site.State.Equals("Started", StringComparison.OrdinalIgnoreCase);
            var statusClass = isRunning ? "running" : "stopped";
            var statusBadgeClass = isRunning ? "bg-success" : "bg-danger";
            
            <div class="col">
                <div class="site-card h-100 d-flex flex-column">
                    <div class="card-header">
                        <div class="d-flex align-items-center" style="max-width: 70%;">
                            <span class="status-indicator @statusClass" title="@site.State"></span>
                            <h5 class="card-title text-truncate" title="@site.Name">@site.Name</h5>
                        </div>
                        <span class="badge @statusBadgeClass rounded-pill shadow-sm py-2">@site.State</span>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <p class="text-muted small mb-2"><i class="bi bi-folder2-open me-1"></i> <strong>Path:</strong><br /> <span class="text-truncate d-block" title="@site.PhysicalPath">@site.PhysicalPath</span></p>
                        <p class="text-muted small mb-4"><i class="bi bi-link-45deg me-1"></i> <strong>Bindings:</strong><br />
                            @if(site.Bindings.Any())
                            {
                                foreach(var binding in site.Bindings.Take(2))
                                {
                                    <span class="d-block text-truncate" title="@binding">@binding</span>
                                }
                                if(site.Bindings.Count > 2)
                                {
                                    <span class="d-block text-primary small" style="cursor:help;" title="@string.Join('\n', site.Bindings)">+ @(site.Bindings.Count - 2) more</span>
                                }
                            }
                            else
                            {
                                <span>None</span>
                            }
                        </p>
                        
                        <div class="d-flex justify-content-between mt-auto border-top border-secondary pt-3 pt-opacity-25">
                            <form method="post" asp-action="ToggleState" class="w-100 d-flex gap-2">
                                <input type="hidden" name="siteName" value="@site.Name" />
                                
                                @if (isRunning)
                                {
                                    <button type="submit" name="command" value="stop" class="btn btn-outline-danger flex-fill btn-sm fw-medium shadow-sm">
                                        <i class="bi bi-stop-circle me-1"></i> Stop
                                    </button>
                                    <button type="submit" name="command" value="restart" class="btn btn-outline-warning flex-fill btn-sm fw-medium shadow-sm">
                                        <i class="bi bi-arrow-repeat me-1"></i> Restart
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" name="command" value="start" class="btn btn-outline-success flex-fill btn-sm fw-medium shadow-sm">
                                        <i class="bi bi-play-circle me-1"></i> Start
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary flex-fill btn-sm disabled fw-medium shadow-sm">
                                        <i class="bi bi-arrow-repeat me-1"></i> Restart
                                    </button>
                                }
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info shadow-sm">
        <i class="bi bi-info-circle-fill me-2"></i> No active sites found on the current IIS server.
    </div>
}
